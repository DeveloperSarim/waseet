# ─────────────────────────────────────────────────────────────────────────────
#  Waseet — production environment (root). Copied to `.env` and filled by install.sh.
#  Everything here is consumed by docker-compose.yml AND the backend container.
#  Secrets marked CHANGE_ME are auto-generated by install.sh.
# ─────────────────────────────────────────────────────────────────────────────

# ---- App ----
NODE_ENV=production
PORT=19000
APP_PORT=8080                     # host loopback port the reverse-proxy forwards to
APP_URL=https://your-domain.com   # public URL (used in emails); install.sh sets this
CORS_ORIGIN=https://your-domain.com
# Set false when serving over plain HTTP (IP:port, no SSL) so sessions persist.
# Leave true for a real domain with HTTPS. install.sh sets this automatically.
COOKIE_SECURE=true

# ---- Admin bootstrap (install.sh asks for these) ----
ADMIN_EMAIL=admin@waseet.com
ADMIN_PASSWORD=CHANGE_ME

# ---- PostgreSQL ----
POSTGRES_USER=waseet
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=waseet
DATABASE_URL=postgresql://waseet:CHANGE_ME@postgres:5432/waseet

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379

# ---- Object storage (RustFS, S3-compatible) ----
S3_ENDPOINT=http://rustfs:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET_PUBLIC=waseet-public
S3_BUCKET_PRIVATE=waseet-private
S3_FORCE_PATH_STYLE=true

# ---- Auth / crypto ----
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
ENCRYPTION_KEY=CHANGE_ME          # 32-byte base64 (AES-256-GCM)

# ---- SMTP (leave SMTP_HOST empty to log emails instead of sending) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Waseet <no-reply@your-domain.com>
