# dependencies
node_modules/

# build output
dist/
build/
.vite/

# runtime data (regenerated)
waseet-backend/backups/*
!waseet-backend/backups/.gitkeep

# os / editor / logs
.DS_Store
Thumbs.db
*.log
npm-debug.log*

# env files hold secrets — NEVER commit them (the repo is public).
# Copy the *.env.example templates and fill them locally / via install.sh.
.env
.env.local
**/.env
!**/.env.example

# backups (generated by backup.sh)
/backups/
