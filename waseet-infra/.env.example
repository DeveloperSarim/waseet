# ============================================================
#  Waseet — LOCAL dev infrastructure (waseet-infra/). Copy to `.env`.
#  These are localhost-only defaults (ports bound to 127.0.0.1).
#  For a real server, use install.sh at the repo root instead.
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=waseet
POSTGRES_PASSWORD=waseet_secret
POSTGRES_DB=waseet
POSTGRES_PORT=19432

# ---- pgweb (simple Postgres UI — no login) ----
PGWEB_PORT=19050

# ---- Object storage (S3-compatible) ----
MINIO_ROOT_USER=waseet
MINIO_ROOT_PASSWORD=waseet_minio_secret
MINIO_API_PORT=19900
MINIO_CONSOLE_PORT=19901

# ---- Redis ----
REDIS_PASSWORD=waseet_redis_secret
REDIS_PORT=19379
